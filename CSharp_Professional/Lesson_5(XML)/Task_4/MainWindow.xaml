<Window x:Class="Task_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task_4"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="68" />
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="Вхід у додаток" VerticalAlignment="Top" FontSize="20" IsEnabled="False" Height="40" Width="190" Margin="0,10,0,0"/>
        <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="Логін:" VerticalAlignment="Top" FontSize="24" Margin="10,10,0,0" Height="42" Width="75" Grid.Row="1"/>
        <TextBox x:Name="loginTextBox" HorizontalAlignment="Left" Margin="118,0,0,0" TextWrapping="Wrap" Text="UserName" VerticalAlignment="Center" Width="219" FontSize="24" TextAlignment="Center" GotFocus="loginTextBox_GotFocus" LostFocus="loginTextBox_LostFocus" Height="32" Grid.Row="1" Foreground="#FF9D9D9D"/>
        <TextBlock HorizontalAlignment="Left" Grid.Row="3" TextWrapping="Wrap" Text="Доступні логіни: User, Admin" VerticalAlignment="Top" Width="356" TextAlignment="Center" Margin="4,11,0,0" Height="36"/>
        <Button x:Name="enterButton" Content="Увійти" HorizontalAlignment="Center" VerticalAlignment="Center" Width="190" Height="44" Grid.Row="2" IsDefault="True" Click="enterButton_Click"/>

    </Grid>
</Window>
