<Window x:Class="MyReflector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyReflector"
        mc:Ignorable="d"
        Title="WPF REFLECTOR" Height="650" Width="1000">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Відкрити збірку..." Click="OpenMenuItem_Click"/>
                <Separator />
                <MenuItem Header="Вихід" Click="CloseMenuItem_Click"/>
            </MenuItem>
        </Menu>
        <Grid Background="#F5F5F7">
            <TextBox Name="ResultTextBox" 
                     Margin="10" 
                     FontFamily="Consolas" 
                     FontSize="13"
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto" 
                     IsReadOnly="True" 
                     AcceptsReturn="True" />
        </Grid>
    </DockPanel>
</Window>
