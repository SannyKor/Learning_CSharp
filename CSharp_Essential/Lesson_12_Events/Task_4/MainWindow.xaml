<Window x:Class="Task_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task_4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="413,142,0,0" TextWrapping="Wrap" Text="=" VerticalAlignment="Top" RenderTransformOrigin="0.154,-0.599"/>
        <Button x:Name="SumButton" Content="Sum" HorizontalAlignment="Left" Height="42" Margin="106,237,0,0" VerticalAlignment="Top" Width="88" Click="SumButton_Click"/>
        <Button x:Name="DivideButton" Content="Divide" HorizontalAlignment="Left" Height="42" Margin="509,237,0,0" VerticalAlignment="Top" Width="88" Click="DivideButton_Click"/>
        <Button x:Name="MultiplyButton" Content="Multiply" HorizontalAlignment="Left" Height="42" Margin="378,237,0,0" VerticalAlignment="Top" Width="87" Click="MultiplyButton_Click"/>
        <Button x:Name="SubtractButton" Content="Subtract" HorizontalAlignment="Left" Height="42" Margin="236,237,0,0" VerticalAlignment="Top" Width="88" Click="SubtractButton_Click"/>
        <TextBox x:Name="ResultTextBox" HorizontalAlignment="Left" Margin="441,139,0,0" TextWrapping="Wrap" Text="Result" VerticalAlignment="Top" Width="98" IsReadOnly="True" HorizontalContentAlignment="Center"/>
        <TextBlock x:Name="OperationTextBlock" HorizontalAlignment="Left" Margin="250,141,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="44" Height="22" TextAlignment="Center"/>
        <TextBox x:Name="Value1TextBox" HorizontalAlignment="Left" Margin="168,141,0,0" TextWrapping="Wrap" Text="Value" VerticalAlignment="Top" Width="82" GotFocus="ValueTextBox_GotFocus" HorizontalContentAlignment="Center"/>
        <TextBox x:Name="Value2TextBox" HorizontalAlignment="Left" Margin="294,140,0,0" TextWrapping="Wrap" Text="Value" VerticalAlignment="Top" Width="94" GotFocus="ValueTextBox_GotFocus" HorizontalContentAlignment="Center"/>

    </Grid>
</Window>
